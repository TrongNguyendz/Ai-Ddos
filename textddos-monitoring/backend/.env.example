# DDoS Monitoring Backend Environment Variables

# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=textddos_db

# Application Settings
APP_NAME=TextDDOS Monitoring API
DEBUG=True
VERSION=1.0.0
PORT=8000

# CORS Settings
ALLOWED_ORIGINS=["http://localhost:5173", "http://localhost:5174", "http://localhost:3000"]

# WebSocket Settings
WS_MAX_CONNECTIONS=1000
WS_PING_INTERVAL=30

# AI Model Settings
MODEL_PATH=./models/ddos_model.pkl
MODEL_THRESHOLD=0.8

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# API Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Alert Settings
ALERT_HIGH_CONFIDENCE=0.9
ALERT_MEDIUM_CONFIDENCE=0.7
ALERT_LOW_CONFIDENCE=0.5

# Cloudflare Configuration (For IP Blocking)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id_optional

# Redis Configuration (For Rate Limiting)
REDIS_URL=redis://localhost:6379/0

# Telegram Configuration (For Alerts)
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Packet Sniffer & Traffic Simulation
ENABLE_SNIFFER=True
SNIFFER_INTERFACE=
ENABLE_SIMULATION=True

